node_modules/
dist/
apps/*/dist/
.env
.env.local
logs/*.log
config/local.env
config/*.plist
*.log
.DS_Store

# Electron staged build copies + packaging output (regenerated by npm run build / npm run dist)
apps/desktop/server/
apps/desktop/web/
apps/desktop/dist-electron/
apps/desktop/.temp-npm-install/

# Old bash-based packaging artifacts (superseded by apps/desktop's Electron build)
dist-app/

# Resolved launchd plists contain a real absolute machine path — only the .template is tracked
launchd/*.plist
!launchd/*.plist.template

# TS incremental build caches / stray compiled config artifacts
*.tsbuildinfo
apps/web/vite.config.js
apps/web/vite.config.d.ts
