{
  "name": "study-command-center",
  "version": "1.0.0",
  "description": "VERITY Native for macOS with retained Electron 1.x compatibility workspaces",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/server",
    "apps/web",
    "apps/desktop"
  ],
  "scripts": {
    "build": "npm run build:legacy",
    "build:legacy": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev --workspace=apps/server\" \"npm run dev --workspace=apps/web\"",
    "start": "npm start --workspace=apps/server"
  },
  "devDependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "concurrently": "^8.2.2"
  }
}
